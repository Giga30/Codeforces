import sys
input = sys.stdin.readline

def main():
    t = int(input())
    for _ in range(t):
        n, k = map(int, input().split())
        s = input().strip()
        result = True
        for i in range(n):
            if i < n-k and s[i] != s[i+k]:
                result = False
            elif i >= n-k and i < n and s[i] == 1:
                print(i)
                result = False

        
        print("YES" if result else "NO")
        

if __name__ == "__main__":
    main()
